{
  "manifest_version": 3,
  "name": "Chirpy",
  "version": "1.0.0",
  "version_name": "1.0.0",
  "description": "Highlight text on any webpage and chat with AI about it",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/purify.js",
        "lib/marked.js",
        "core.js",
        "highlight.js",
        "bubble.js",
        "events.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "open-page-chat": {
      "suggested_key": {
        "default": "Alt+C"
      },
      "description": "Open Chirpy page chat"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "bubble.css",
        "tooltip.html",
        "lib/marked.js",
        "icons/icon16.png",
        "icons/icon48.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
