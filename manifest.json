{
  "manifest_version": 3,
  "name": "Chirpy",
  "version": "1.26.2.1215",
  "version_name": "1.26.02.1215",
  "description": "Highlight text on any webpage and chat with AI about it",
  "permissions": ["activeTab", "storage", "contextMenus", "tabs"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/marked.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["bubble.css", "lib/marked.min.js", "icons/icon16.png", "icons/icon48.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
